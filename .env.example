# Llama AI API Configuration
# Add your API keys for the Llama providers you want to use

# Together AI (Recommended - Best for vision models)
VITE_TOGETHER_API_KEY=your_together_api_key_here

# Hugging Face (Good free tier)
VITE_HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Replicate (Pay per use)
VITE_REPLICATE_API_TOKEN=your_replicate_token_here

# Note: Ollama runs locally and doesn't need an API key
# To use Ollama, install it from https://ollama.ai and run:
# ollama pull llama3.2-vision:11b

# API URLs (optional - uses defaults if not specified)
# VITE_TOGETHER_API_URL=https://api.together.xyz/v1/chat/completions
# VITE_HUGGINGFACE_API_URL=https://api-inference.huggingface.co/models/
# VITE_REPLICATE_API_URL=https://api.replicate.com/v1/predictions